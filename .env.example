# Shared
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# Database and queue
DATABASE_URL=postgresql+psycopg://bugswarm:bugswarm@localhost:5432/bugswarm
REDIS_URL=redis://localhost:6379/0

# Security
JWT_SECRET=change-me-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Artifact storage
ARTIFACT_STORAGE_ROOT=storage
SCREENSHOT_RETENTION_DAYS=90
TRACE_RETENTION_DAYS=30
REPORT_RETENTION_DAYS=180
BROWSER_LOG_RETENTION_DAYS=90
NETWORK_LOG_RETENTION_DAYS=90
BUGSWARM_DEMO_BASE_URL=http://localhost:8090

# Free-compatible AI defaults
AI_FREE_MODE=true
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/auto
GPTOSS_BASE_URL=http://localhost:11434/v1
GPTOSS_MODEL=gpt-oss-20b
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# Agent limits
DEFAULT_AGENT_COUNT=3
DEFAULT_MAX_DEPTH=3
DEFAULT_MAX_DURATION_MINUTES=30
MAX_AGENT_COUNT=8
WORKER_CONCURRENCY=4
WORKER_AUTOSCALE=
CELERY_LOG_LEVEL=INFO
CELERY_QUEUE_NAMES=celery
QUEUE_AUTOSCALE_TARGET_PENDING_PER_REPLICA=4
QUEUE_AUTOSCALE_MIN_WORKER_REPLICAS=1
QUEUE_AUTOSCALE_MAX_WORKER_REPLICAS=10
RUN_MIGRATIONS=true
